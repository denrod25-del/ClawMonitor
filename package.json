{
  "name": "clawmonitor",
  "version": "0.1.0",
  "description": "Always-on-top neon system monitor bar for Windows",
  "main": "main/index.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.skyea.clawmonitor",
    "productName": "ClawMonitor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "koffi": "^3.0.2",
    "systeminformation": "^5.22.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1",
    "vitest": "^2.0.0"
  }
}
